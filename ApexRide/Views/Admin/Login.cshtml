@model Admin

<h2>Admin Login</h2>

<form asp-action="Login" method="post">

    <div class="mb-3">
        <label>Username</label>
        <input asp-for="Username"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="Password"
               type="password"
               class="form-control" />
    </div>

    <button class="btn btn-dark">
        Login
    </button>

</form>